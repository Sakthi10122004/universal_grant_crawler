# ─────────────────────────────────────────────
# universal_grant_crawler — .gitignore
# Frappe App | Python | Playwright | LLM/API
# ─────────────────────────────────────────────


# ── OS & Editor ──────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.iml
.editorconfig.local


# ── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.eggs/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Testing & coverage
.pytest_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
nosetests.xml


# ── Frappe-specific ──────────────────────────
# Auto-generated site config (never commit site secrets)
sites/*/site_config.json
sites/common_site_config.json
sites/currentsite.txt

# Frappe build artefacts
*.pyc
tags
node_modules/
.yarn/

# Patches log (auto-generated on migration)
patches.log

# Frappe desktop cache / session files
*.lock
frappe/public/dist/
frappe/public/build.json


# ── JavaScript / Node ────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
dist/
.parcel-cache/
*.tsbuildinfo


# ── Playwright & Browser Automation ──────────
# Playwright browser binaries (large, downloadable on demand)
.playwright/
playwright-browsers/
ms-playwright/

# Playwright test artefacts
playwright-report/
test-results/
*.png           # screenshots captured during scrapes
*.webp
*.zip           # traces

# Crawl session state / storage
auth_state.json
storage_state.json
session_cookies.json
browser_state/


# ── Scraping & Crawler Artefacts ─────────────
# Raw HTML / page dumps saved during crawls
raw_html/
page_dumps/
*.html.gz

# Download cache directories
downloads/
crawl_cache/
cache/
.cache/

# Output data files (keep schemas, ignore raw dumps)
output/
results/
data/
*.jsonl
scraped_*.json
scraped_*.csv

# Log files generated by the crawler
logs/
*.log
crawler.log
scrape_*.log


# ── LLM / API Secrets ────────────────────────
# Never commit API keys, tokens, or provider configs
.env
.env.*
!.env.example          # keep the example template
secrets.json
api_keys.json
credentials.json
*.pem
*.key
*.p12
*.pfx
service_account*.json
google_credentials*.json


# ── Jupyter / IPython ────────────────────────
.ipynb_checkpoints/
*.ipynb


# ── Temporary & Misc ─────────────────────────
*.tmp
*.bak
*.orig
*.rej
tmp/
temp/
.tmp/